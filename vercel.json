{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "style.css",
          "games.css",
          "logo.svg",
          "launcher.js",
          "BosnanGame.jar",
          "data/**",
          "images/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
